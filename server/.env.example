# Server
PORT=3001
DB_PATH=./data.sqlite
POLL_INTERVAL_MS=60000
REQUEST_TIMEOUT_MS=10000

# Email (SMTP) - optional
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=monitor@example.com
EMAIL_TO=alerts@example.com

# Push notifications (Firebase Admin) - optional
PUSH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PUSH_CLICK_URL=http://localhost:5173/monit/
